# Twitter Collector — scheduled Twitter/X collection pipeline
# Build with: podman build -f container/Containerfile -t k12-twitter-collector:local .
# from the twitter-collector repo root (app/ common/ container/ が必要)
FROM python:3.12-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY app/ /app/app/
COPY common/ /app/common/
COPY container/ /app/container/

WORKDIR /app/app

RUN python -m venv .venv \
    && .venv/bin/pip install --no-cache-dir \
        -e /app/common \
        -e . \
        "twitter-cli @ git+https://github.com/jackwener/twitter-cli.git@e496d8f8708d71800188cfb23f24b2b6fd4b94b9" \
        python-dotenv

RUN mkdir -p /data /auth

COPY container/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

VOLUME ["/data", "/auth"]

ENTRYPOINT ["/entrypoint.sh"]
